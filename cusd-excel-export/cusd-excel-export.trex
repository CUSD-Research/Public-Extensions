<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.cusd80.research.excelexport" extension-version="0.1.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>CUSD Research one-click Excel download. The dashboard author chooses which worksheet(s) the button is allowed to export; end users click once and get an .xlsx with no sheet-selection dialog.</description>
    <author name="CUSD Research and Data Analytics" email="research@cusd80.com" organization="Chandler Unified School District" website="https://www.cusd80.com"/>
    <min-api-version>1.10</min-api-version>
    <source-location>
      <!-- GitHub Pages URL: org CUSD-Research, repo Public-Extensions, this extension in
           the cusd-excel-export/ subfolder. Pages paths are case-sensitive, so the repo
           name's capitals must match exactly. Allow-list the host
           https://cusd-research.github.io on the Tableau Cloud site. -->
      <url>https://cusd-research.github.io/Public-Extensions/cusd-excel-export/index.html</url>
    </source-location>
    <icon></icon>
    <!-- "full data" lets the extension read the worksheet's summary data so it can be written to Excel.
         The extension never sends that data anywhere — it is built into the file in the browser. -->
    <permissions>
      <permission>full data</permission>
    </permissions>
    <!-- Adds the "Configure…" item to the extension's drop-down so authors can pick the allowed sheets. -->
    <context-menu>
      <configure-context-menu-item/>
    </context-menu>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">CUSD Excel Export</text>
    </resource>
  </resources>
</manifest>
