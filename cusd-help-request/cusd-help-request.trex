<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.cusd80.research.helprequest" extension-version="0.1.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>CUSD Research "Request help" button. Composes a pre-filled email to your team inbox with the dashboard name, current filters/parameters, environment, and a timestamp, so support requests arrive with the context already attached. Reads no worksheet data and makes no network calls of its own.</description>
    <author name="CUSD Research and Data Analytics" email="research@cusd80.com" organization="Chandler Unified School District" website="https://www.cusd80.com"/>
    <min-api-version>1.4</min-api-version>
    <source-location>
      <!-- GitHub Pages URL: org CUSD-Research, repo Public-Extensions, this extension in
           the cusd-help-request/ subfolder. Pages paths are case-sensitive, so the repo
           name's capitals must match exactly. Allow-list the host
           https://cusd-research.github.io on the Tableau Cloud site. -->
      <url>https://cusd-research.github.io/Public-Extensions/cusd-help-request/index.html</url>
    </source-location>
    <icon></icon>
    <!-- No <permissions> block: this extension reads only dashboard metadata
         (names, filter/parameter selections, environment) to build the email — it
         never reads worksheet data — so viewers get no data-access prompt. If a
         future Tableau build requires "full data" to read filter VALUES, add
         <permissions><permission>full data</permission></permissions> here (right
         after this comment) and re-add the extension. -->
    <!-- Adds the "Configure…" item so the author can set the recipient + options. -->
    <context-menu>
      <configure-context-menu-item/>
    </context-menu>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">CUSD Request Help</text>
    </resource>
  </resources>
</manifest>
