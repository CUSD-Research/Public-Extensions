<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.cusd80.research.kpitable" extension-version="0.1.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>CUSD Research in-line KPI table. The dashboard author points it at one flat worksheet and maps each column to a mark (bar, KPI circle, pie/donut, trend arrow, thumb, sparkline, status pill) with its own scale, comparison basis, and color rule — replacing the MIN(1) dual-axis scaffold technique. Reads summary data only; row-level security is respected.</description>
    <author name="CUSD Research and Data Analytics" email="research@cusd80.com" organization="Chandler Unified School District" website="https://www.cusd80.com"/>
    <min-api-version>1.10</min-api-version>
    <source-location>
      <!-- GitHub Pages: org CUSD-Research, repo Public-Extensions, this extension in
           the cusd-kpi-table/ subfolder. Pages paths are case-sensitive, so the repo
           name's capitals must match exactly. Allow-list https://cusd-research.github.io
           on the Tableau Cloud site (Settings -> Extensions). -->
      <url>https://cusd-research.github.io/Public-Extensions/cusd-kpi-table/index.html</url>
    </source-location>
    <icon></icon>
    <!-- "full data" lets the extension read the source worksheet's summary data so it
         can draw the marks. Data never leaves the browser; nothing is written anywhere. -->
    <permissions>
      <permission>full data</permission>
    </permissions>
    <!-- Adds the "Configure..." item so authors can map columns to marks. -->
    <context-menu>
      <configure-context-menu-item/>
    </context-menu>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">CUSD KPI Table</text>
    </resource>
  </resources>
</manifest>
